# Jordy - Python backend environment variables
# Copy this file and fill in your values before running the server.

# ── User Agent (recommended, especially for SEC EDGAR) ───────────────────────
# EQUITY_BOT_USER_AGENT="your-app-name/0.1 (email@domain.com)"

# ── Groww Trading API ─────────────────────────────────────────────────────────
# Preferred: TOTP flow (automation-friendly, no daily approval needed)
GROWW_TOTP_TOKEN=""
GROWW_TOTP_SECRET=""

# Alternative: API key + secret flow (requires daily approval from Groww)
# GROWW_API_KEY=""
# GROWW_API_SECRET=""

# Alternative: paste a pre-minted access token directly
# GROWW_ACCESS_TOKEN=""
